# Template for host-specific runtime config.
# Copy to `.env` on the deploy host and set the value for THAT machine:
#   cp .env.template .env
# `.env` is gitignored; this template is committed as documentation.
#
# WEB_BIND_IP: the host interface Docker publishes port 3000 on, so a reverse
# proxy (Nginx Proxy Manager, on another host) can reach the app. It MUST be an
# IP this machine actually owns — check with: ip -4 addr show
# If `.env` is absent, docker-compose.yml falls back to 127.0.0.1 (loopback),
# which fails CLOSED (unreachable from other hosts) rather than exposed.
WEB_BIND_IP=192.168.0.118
